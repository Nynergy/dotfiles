*.color15:	#ffd7c0

!! URxvt Appearance
URxvt*font: xft:Terminus:pixelsize=14

! Fake Transparency
!URxvt*transparent: true
!URxvt*shading: 30
!URxvt*depth: 24

! True Transparency
URxvt*depth: 32
URxvt*background: [75]#151110

URxvt.highlightColor: white
URxvt.highlightTextColor: black

! Dynamic Colors
URxvt*dynamicColors: on

URxvt.letterSpace: 1
URxvt.lineSpace: 0
URxvt.externalBorder: 16
URxvt.cursorBlink: true
URxvt.cursorUnderline: false
URxvt.saveline: 2048
URxvt.scrollBar: false
URxvt.scrollBar_right: false
URxvt.iso14755: false

! Keysym Bindings
URxvt.keysym.Control-Up:     \033[1;5A
URxvt.keysym.Control-Down:   \033[1;5B
URxvt.keysym.Control-Left:   \033[1;5D
URxvt.keysym.Control-Right:  \033[1;5C

URxvt.keysym.C-minus: 	command:\033]710;xft:Terminus:pixelsize=8\007
URxvt.keysym.C-0:	    command:\033]710;xft:Terminus:pixelsize=14\007
URxvt.keysym.C-plus:	command:\033]710;xft:Terminus:pixelsize=20\007

!! Xorg Variables
Xft.dpi: 100

! Fix for prompt appearing mid-terminal
! Commented out due to complications with floating terminals
!URxvt*geometry: 80x240+0+0
