!!Colors
! special
*.foreground:	#ffd7c0
*.background:	#151110
*.cursorColor:	#ffd7c0

! black
*.color0:	#151110
*.color8:	#c1b7b7

! red
*.color1:	#f02060
*.color9:	#f02060

! green
*.color2:	#79f4c2
*.color10:	#79f4c2

! yellow
*.color3:	#ffb060
*.color11:	#ffb060

! blue
