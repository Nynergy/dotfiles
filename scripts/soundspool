#!/usr/bin/env bash

# A script to turn squeezelite on and off

# Maintainer:       Ben Buchanan
# Version:          1.0.3
# Last Modified:    11-Jun-2026

die() {
    dunstify 'ERROR' "$1"
    exit 1
}

ENV_FILE="$HOME/.env.sh"
(( EUID == 0 )) && ENV_FILE="/.env.sh"

[[ -f "$ENV_FILE" ]] || die "Could not locate env file at '$ENV_FILE'"
# shellcheck disable=SC1090
source "$ENV_FILE"

if ! pkill squeezelite
then
    squeezelite -s "$LMS_IP_ADDRESS" -n "$(hostname)" &
fi
